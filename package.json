{
  "name": "guildwars1-mcp",
  "version": "1.3.1",
  "description": "Read-only MCP server for Guild Wars 1 public sources and opt-in local inventory.",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "guildwars1-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "tsx src/index.ts",
    "prepare": "npm run build",
    "skills:build": "node scripts/build-skill-index.mjs",
    "skills:check": "node scripts/build-skill-index.mjs --check",
    "smoke:sources": "npm run build && node scripts/source-smoke.mjs",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "guild-wars",
    "guild-wars-1",
    "gw1",
    "guildwars",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "typescript",
    "mediawiki",
    "pvxwiki",
    "gw1builds",
    "youtube",
    "content-discovery",
    "game-data",
    "read-only"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
